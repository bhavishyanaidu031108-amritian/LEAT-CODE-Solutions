# LeetCode 11 - Container With Most Water
# My initial solution (Time Limit Exceeded)
# Complexity: O(n^2)

class Solution:
    def maxArea(self, height):
        n = len(height)
        max_area = 0

        for i in range(n):
            for j in range(i + 1, n):
                area = (j - i) * min(height[i], height[j])

                if area > max_area:
                    max_area = area

        return max_area