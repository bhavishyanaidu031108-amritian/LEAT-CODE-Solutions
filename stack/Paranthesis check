class Solution:
def check(self,s):
    stack=[]
    for i in s:
        if i is '('or i is '{'or i is '[':
            stack.append(i)
        else if i is ')'or i is '}'or i is']':
            top=stack.pop()
            if i is ')'and top is not'(':
                return False
            if i is '}'and top is not'{':
                return False
            if i is ']'and top is not '[':
                return False
        if len(stack)==0:
            return True
        else:
            return False
                            

