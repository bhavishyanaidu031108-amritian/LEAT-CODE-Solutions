class Solution:

    def reverse(self, x):
        reverse_x = 0
        sign = 1

        if x < 0:
            sign = -1

        x = abs(x)          

        while x > 0:
            digit = x % 10
            reverse_x = reverse_x * 10 + digit
            x = x // 10

        reverse_x = reverse_x * sign

        int_max = (2**31) - 1
        int_min = -2**31

        if int_min <= reverse_x <= int_max:
            return reverse_x
        else:
            return 0
        
        